[sub_resource type="GDScript" id="GDScript_6fb4b"]
script/source = "class_name GroundedMovementState
extends State


var direction : float = 0.0


func enter() -> void:
	_propagate_enter()
	direction = 0.0


func exit() -> void:
	direction = 0.0
	_propagate_exit()


func process() -> void:
	_propagate_process()


func physics_process() -> void:
	_propagate_physics_process()

	if has_parent_state():
		direction = parent_state.direction

	_handle_transitions()


func _handle_transitions() -> void:
	pass
"

